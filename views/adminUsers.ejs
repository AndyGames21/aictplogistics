  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>User Management | AICTP Logistics</title>
  <link rel="stylesheet" href="/css/adminUsers.css" />
  <link rel="shortcut icon" href="/images/logo.jpg" type="image/x-icon" />
  <% if (user && user.role === 'admin') { %>
  <nav class="navbar">
    <a href="/" class="logo-link"><div class="logo-section">
      <img src="/images/logo.jpg" alt="AICTP Logo" class="logo" />
      <span class="brand-name">AICTP Logistics</span>
    </div>
    </a>

    <div class="hamburger" id="hamburger">
      <div></div>
      <div></div>
      <div></div>
    </div>

    <ul class="nav-links" id="navLinks">
      <li><a href="/dashboard">Dashboard</a></li>
      <li><a href="/bookingAdmin">All Bookings</a></li>
      <li><a href="/logout">Logout</a></li>
      <li><a href="/services">Services</a></li>
      <li><a href="/contact">Contact Us</a></li>
    </ul>
  </nav>
  <% } %>

  <div class="container">
    <div class="table-responsive">
      <h2>User Management</h2>
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Fullname</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Role</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(user => { %>
            <tr>
              <td><%= user.id %></td>
              <td><%= user.fullname %></td>
              <td><%= user.email %></td>
              <td><%= user.phone %></td>
              <td><%= user.role %></td>
            <td>
              <% if (user.role !== 'admin') { %>
                <div class="action-buttons">
                  <!-- Delete Button -->
                  <form method="POST" action="/delete-user/<%= user.id %>" onsubmit="return confirm('Are you sure you want to delete this user?');">
                    <button type="submit" class="btn delete">Delete</button>
                  </form>

                  <!-- Promote Button -->
                  <form method="POST" action="/promote-user/<%= user.id %>" onsubmit="return confirm('Are you sure you want to promote this user to admin?');">
                    <button type="submit" class="btn promote">Promote</button>
                  </form>
                </div>
              <% } else { %>
                <em>Admin</em>
              <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<script src="/js/adminUsers.js" defer></script>